	(text "DW01A + 8205A"
		(exclude_from_sim no)
		(at 250.444 20.066 0)
		(effects
			(font
				(size 2.54 2.54)
			)
		)
		(uuid "61e54d37-c57f-426e-b697-adda99a224e6")
	)
	(text "The R3 resistor, connected between the programming pin (PROG / Pin 2) of the TP4056 linear charging IC and the system ground (GND),\nserves as a critical parameter adjustment element that directly determines the charging current of the circuit.\nBy modifying the value of this resistor, the output current of the module can be flexibly adjusted\nto match the specific capacity and safe charging limits of the lithium battery being used. \nWhile the default design utilizes a 1.2 kΩ resistor to provide a full 1000 mA (1A) charging current, \nthe value of the R3 resistor must be progressively increased to protect lower-capacity batteries \nfrom overheating and structural damage; for instance, \nalternative resistance values such as 1.5 kΩ for 800 mA, \n2.4 kΩ for 500 mA, and up to 10 kΩ for smaller batteries (130 mA) can be selected to program the charging cycle within entirely safe thresholds."
		(exclude_from_sim no)
		(at 13.208 146.558 0)
		(effects
			(font
				(size 2.286 2.286)
				(thickness 0.3175)
			)
			(justify left)
		)
		(uuid "a8b5aae4-b4d4-43f1-ba81-72837a3f873d")
	)
	(text "USB-C"
		(exclude_from_sim no)
		(at 76.962 80.518 0)
